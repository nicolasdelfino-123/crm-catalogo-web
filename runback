#!/usr/bin/env bash
set -e
SCRIPT_PATH="$(readlink -f "$0")"
cd "$(dirname "$SCRIPT_PATH")/backend"
if [ ! -d .venv ]; then python3 -m venv .venv; fi
# Invoke tools through Python instead of their generated launchers. Those
# launchers contain an absolute path and stop working when the project moves.
.venv/bin/python -m pip install -q -r requirements.txt
export SQLALCHEMY_DATABASE_URI="${SQLALCHEMY_DATABASE_URI:-sqlite:///crm.db}"
mkdir -p instance
if [ -z "${JWT_SECRET_KEY:-}" ]; then
  JWT_SECRET_FILE="instance/.jwt-secret"
  if [ ! -s "$JWT_SECRET_FILE" ]; then
    umask 077
    od -An -N32 -tx1 /dev/urandom | tr -d ' \n' > "$JWT_SECRET_FILE"
  fi
  JWT_SECRET_KEY="$(<"$JWT_SECRET_FILE")"
  export JWT_SECRET_KEY
fi
if [ ! -f instance/crm.db ]; then .venv/bin/python seed.py; fi
exec .venv/bin/python -m flask --app app.run run --host=0.0.0.0
