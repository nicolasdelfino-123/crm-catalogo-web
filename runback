#!/usr/bin/env bash
set -e
SCRIPT_PATH="$(readlink -f "$0")"
cd "$(dirname "$SCRIPT_PATH")/backend"
if [ ! -d .venv ]; then python3 -m venv .venv; fi
.venv/bin/pip install -q -r requirements.txt
export SQLALCHEMY_DATABASE_URI="${SQLALCHEMY_DATABASE_URI:-sqlite:///crm.db}"
export JWT_SECRET_KEY="${JWT_SECRET_KEY:-local-development-only}"
if [ ! -f instance/crm.db ]; then .venv/bin/python seed.py; fi
exec .venv/bin/flask --app app.run run --host=0.0.0.0
